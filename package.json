{
  "name": "reflix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev",
    "build": "node scripts/prepare-protected-public-build.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:browse": "playwright test tests/e2e/browse-regression.spec.ts",
    "worker:media:dev": "wrangler dev --config workers/media-gateway/wrangler.toml",
    "worker:media:deploy": "wrangler deploy --config workers/media-gateway/wrangler.toml",
    "export:batch": "node scripts/export.mjs",
    "export:batch:dry": "node scripts/export.mjs --dry-run",
    "export:batch:r2": "node scripts/export.mjs --r2",
    "export:prune": "node scripts/export.mjs --prune",
    "export:prune:dry": "node scripts/export.mjs --prune --dry-run",
    "beta:grant": "node scripts/grant-beta-access.mjs",
    "export:full": "node scripts/export.mjs --full --confirm-full-export",
    "export:local": "node scripts/export.mjs --local",
    "export:r2": "node scripts/export.mjs --local --r2",
    "tags:translate": "node scripts/tag-translate.mjs --write",
    "ai:tag:missing": "node scripts/ai-tag-backfill.mjs",
    "ai:tag:retry-null": "node scripts/ai-tag-backfill.mjs --retry-null",
    "export:batch:ai": "node scripts/ai-tag-backfill.mjs && node scripts/export.mjs",
    "release:scan": "node scripts/release-approval.mjs scan",
    "release:scan:all": "node scripts/release-approval.mjs scan --all",
    "release:review": "node scripts/release-approval.mjs review",
    "release:approve": "node scripts/release-approval.mjs approve",
    "eagle:thumbs:pilot": "node scripts/eagle-thumbnail-pilot.mjs",
    "eagle:thumbs:remaining": "node scripts/eagle-thumbnail-pilot.mjs --remaining",
    "eagle:phase2:review": "node scripts/eagle-phase2.mjs review",
    "eagle:phase2:apply": "node scripts/eagle-phase2.mjs apply",
    "release:go": "node scripts/release-approval.mjs go",
    "release:status": "node scripts/release-approval.mjs status",
    "release:mark-published": "node scripts/release-approval.mjs mark-published",
    "release:mark-failed": "node scripts/release-approval.mjs mark-failed"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@nozbe/microfuzz": "^1.0.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/speed-insights": "^2.0.0",
    "es-hangul": "^2.3.8",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^21.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wrangler": "^4.77.0"
  }
}
