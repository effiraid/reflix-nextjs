# Media URL prefix
# - Local dev and Vercel preview: leave unset to use same-origin /public assets
# - Production only: set to your hosted media origin, for example https://media.reflix.dev
NEXT_PUBLIC_MEDIA_URL=
MEDIA_SESSION_SECRET=
MEDIA_SESSION_COOKIE_DOMAIN=.reflix.dev
MEDIA_SESSION_TTL_SECONDS=21600
PROTECT_MP4_PUBLIC_ASSETS=

# Eagle library path (for export script)
EAGLE_LIBRARY_PATH="/Users/macbook/Desktop/라이브러리/레퍼런스 - 게임,연출.library"

# Cloudflare R2 credentials (for export script)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=reflix-media

# Optional reference for the hosted public origin
R2_PUBLIC_URL=https://media.reflix.dev
